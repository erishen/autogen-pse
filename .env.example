# Multi-provider keys (供 Makefile 引用，不要提交到 git)
DEEPSEEK_KEY=your-deepseek-key
AGNES_KEY=your-agnes-key

# Optional: disable streaming for unstable providers (e.g. Agnes free tier)
# PSE_MODEL_STREAM=false

# External project paths
ASSET_LENS_DIR=/path/to/asset-lens
MONEY_CSV_DIR=/path/to/market-csv-data

# Optional: knowledge base (langchain-llm-toolkit RAG)
# KNOWLEDGE_BASE_PATH=/path/to/rag-project

# Issue detection thresholds
#   LONG_LOSS: days held > threshold AND return < 0
PSE_LONG_LOSS_DAYS=180
#   LOW_EFF: days > threshold AND annualized < max AND amount > min
PSE_LOW_EFF_DAYS=365
PSE_LOW_EFF_MAX_RETURN=2.0
PSE_LOW_EFF_MIN_AMOUNT=10000
#   HIGH_VOL: annualized > min AND days < max AND amount > min
PSE_HIGH_VOL_MIN_RETURN=50
PSE_HIGH_VOL_MAX_DAYS=180
PSE_HIGH_VOL_MIN_AMOUNT=5000
#   LARGE_POS: type in list AND amount > min AND return < max
PSE_LARGE_POS_TYPES=typeA,typeB
PSE_LARGE_POS_MIN_AMOUNT=100000
PSE_LARGE_POS_MAX_RETURN=2.5
#   CUR_LOSS: actual return < threshold AND amount > min (any holding period)
PSE_CUR_LOSS_THRESHOLD=-5
PSE_CUR_LOSS_MIN_AMOUNT=3000

# Market index columns in CSV (comma-separated)
MARKET_INDICES=index1,index2,index3

# Web dashboard CORS (optional, comma-separated)
# CORS_ORIGINS=http://localhost:5173,https://your-app.onrender.com

# Property column mapping (CSV header names, privacy: keep in .env, not in code)
# PROP_CORE_VALUE=住宅估值
# PROP_CORE_ESTIMATE=住宅估价
# PROP_CORE_DIFF=住宅差价
# PROP_CORE_UNITS=在售套数
# PROP_CORE_PRICE=成交均价
# PROP_CORE_LISTING=挂牌价
# PROP_DISTRICTS=区域A,区域B
# PROP_OLD_VALUE=旧资产1,旧资产2

# Market data column mapping (CSV header names, privacy: keep in .env)
# GOLD_GLD_COL=黄金GLD
# GOLD_DOMESTIC_COL=黄金
# GOLD_EXCHANGE_COL=兑换黄金
# MARKET_EXTRA=恐慌VXX,伯克希尔B,美联基利率
