# OpenAI API Configuration
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ── 外部项目路径（必填，指向 asset-lens 和行情数据） ──
ASSET_LENS_DIR=../../invest-kit/apps/asset-lens
MONEY_CSV_DIR=../../invest-kit/apps/ts-demo/data

# ── 知识库（可选，指向 langchain-llm-toolkit，用于 PSE 分析时注入个人投资偏好） ──
# KNOWLEDGE_BASE_PATH=../../invest-kit/apps/langchain-llm-toolkit

# ── 问题检测规则 ──

# 规则 1：长期亏损 — 持有天数超过此值 且 实际收益率为负
PSE_LONG_LOSS_DAYS=180

# 规则 2：资金效率低 — 持有天数超阈值 且 年化低于上限 且 金额高于下限
PSE_LOW_EFF_DAYS=365
PSE_LOW_EFF_MAX_RETURN=2.0
PSE_LOW_EFF_MIN_AMOUNT=10000

# 规则 3：短期高波动 — 年化超过下限 且 持有天数短于上限 且 金额高于下限
PSE_HIGH_VOL_MIN_RETURN=50
PSE_HIGH_VOL_MAX_DAYS=180
PSE_HIGH_VOL_MIN_AMOUNT=5000

# 规则 4：大额固收低效 — 产品类型在列表中 且 金额超过门槛 且 年化低于上限
PSE_LARGE_POS_TYPES=理财,债券,高端理财
PSE_LARGE_POS_MIN_AMOUNT=100000
PSE_LARGE_POS_MAX_RETURN=2.5

# ── 市场指数（逗号分隔，与行情 CSV 的列名一致） ──
MARKET_INDICES=上证指数,沪深300,中证500,纳指100,标普500,黄金GLD,能源XLE

# ── Web Dashboard（可选） ──
# CORS_ORIGINS=http://localhost:5173,https://your-app.onrender.com
