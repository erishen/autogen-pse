# OpenAI API Configuration
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ── 外部项目路径（必填，指向存放行情和投资数据的目录） ──
# ASSET_LENS_DIR: 执行数据生成命令的项目根目录
ASSET_LENS_DIR=/your/project/data-app
# MONEY_CSV_DIR: 存放市场指数 CSV 文件的目录
MONEY_CSV_DIR=/your/project/market-data

# ── 问题检测规则（全部必填） ──

# 规则 1：长期亏损 — 持有天数超过此值 且 实际收益率为负
PSE_LONG_LOSS_DAYS=90

# 规则 2：资金效率低 — 持有天数超阈值 且 年化低于上限 且 金额高于下限
PSE_LOW_EFF_DAYS=180
PSE_LOW_EFF_MAX_RETURN=1.0
PSE_LOW_EFF_MIN_AMOUNT=100

# 规则 3：短期高波动 — 年化超过下限 且 持有天数短于上限 且 金额高于下限
PSE_HIGH_VOL_MIN_RETURN=20
PSE_HIGH_VOL_MAX_DAYS=30
PSE_HIGH_VOL_MIN_AMOUNT=1000

# 规则 4：大额固收低效 — 产品类型在列表中 且 金额超过门槛 且 年化低于上限
PSE_LARGE_POS_TYPES=A,B
PSE_LARGE_POS_MIN_AMOUNT=1000
PSE_LARGE_POS_MAX_RETURN=1.0

# ── 市场指数（必填，逗号分隔，与行情 CSV 的列名一致） ──
MARKET_INDICES=指数A,指数B
